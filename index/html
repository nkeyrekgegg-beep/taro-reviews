<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Отзывы клиентов</title>

  <!-- Google Font -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600&family=Montserrat:wght@300;400;500&display=swap" rel="stylesheet">

  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      min-height: 100vh;
      font-family: 'Montserrat', sans-serif;
      background:
        radial-gradient(circle at top, rgba(255,215,0,0.15), transparent 30%),
        linear-gradient(135deg, #0b0f1a, #1b1330, #09090f);
      color: white;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 30px;
      overflow-x: hidden;
    }

    .stars {
      position: fixed;
      width: 100%;
      height: 100%;
      top: 0;
      left: 0;
      pointer-events: none;
      background-image:
        radial-gradient(2px 2px at 20px 30px, white, transparent),
        radial-gradient(2px 2px at 40px 70px, white, transparent),
        radial-gradient(1px 1px at 90px 40px, white, transparent),
        radial-gradient(2px 2px at 160px 120px, white, transparent);
      background-size: 200px 200px;
      opacity: 0.25;
      animation: moveStars 40s linear infinite;
    }

    @keyframes moveStars {
      from {
        transform: translateY(0);
      }
      to {
        transform: translateY(-200px);
      }
    }

    .form-box {
      position: relative;
      z-index: 2;
      width: 100%;
      max-width: 650px;
      padding: 40px;
      border-radius: 28px;
      background: rgba(15, 15, 25, 0.88);
      backdrop-filter: blur(14px);
      border: 1px solid rgba(255,255,255,0.08);
      box-shadow:
        0 0 30px rgba(147, 51, 234, 0.3),
        0 0 80px rgba(251, 191, 36, 0.08);
    }

    h1 {
      text-align: center;
      font-family: 'Cinzel', serif;
      font-size: 38px;
      margin-bottom: 12px;
      color: #facc15;
      letter-spacing: 1px;
    }

    .subtitle {
      text-align: center;
      color: #d1d5db;
      margin-bottom: 35px;
      font-size: 15px;
      line-height: 1.6;
    }

    label {
      display: block;
      margin-bottom: 10px;
      margin-top: 22px;
      color: #f3f4f6;
      font-weight: 500;
    }

    input,
    textarea,
    select {
      width: 100%;
      padding: 16px;
      border-radius: 16px;
      border: 1px solid rgba(255,255,255,0.08);
      background: rgba(255,255,255,0.05);
      color: white;
      font-size: 15px;
      outline: none;
      transition: 0.3s;
    }

    input:focus,
    textarea:focus,
    select:focus {
      border-color: #facc15;
      box-shadow: 0 0 15px rgba(250,204,21,0.25);
    }

    textarea {
      min-height: 160px;
      resize: vertical;
    }

    select option {
      color: black;
    }

    .checkbox-group {
      margin-top: 25px;
    }

    .checkbox-group label {
      display: flex;
      align-items: center;
      gap: 12px;
      font-weight: 400;
      color: #d1d5db;
    }

    .checkbox-group input {
      width: auto;
      transform: scale(1.1);
    }

    button {
      width: 100%;
      margin-top: 35px;
      padding: 18px;
      border: none;
      border-radius: 18px;
      font-size: 17px;
      font-weight: 600;
      color: white;
      cursor: pointer;
      background: linear-gradient(135deg, #facc15, #9333ea);
      transition: 0.3s;
      letter-spacing: 0.5px;
      box-shadow: 0 0 20px rgba(250,204,21,0.2);
    }

    button:hover {
      transform: translateY(-2px) scale(1.01);
      box-shadow: 0 0 30px rgba(147, 51, 234, 0.4);
    }

    .note {
      margin-top: 22px;
      text-align: center;
      color: #9ca3af;
      font-size: 13px;
      line-height: 1.5;
    }

    .moon {
      position: absolute;
      top: -40px;
      right: -30px;
      width: 120px;
height: 120px;
      background: radial-gradient(circle, #fde68a, #f59e0b);
      border-radius: 50%;
      opacity: 0.15;
      filter: blur(2px);
    }

    @media (max-width: 700px) {
      .form-box {
        padding: 28px;
      }

      h1 {
        font-size: 30px;
      }
    }
  </style>
</head>
<body>

  <div class="stars"></div>

  <div class="form-box">

    <div class="moon"></div>

    <h1>✨ Отзыв о консультации ✨</h1>

    <p class="subtitle">
      Благодарю за доверие и вашу энергию.<br>
      Вы можете оставить отзыв анонимно или разрешить публикацию.
    </p>

    <!-- FORM -->

    <form id="reviewForm">

      <label for="name">Ваше имя (необязательно)</label>
      <input type="text" id="name" placeholder="Например: Анна">

      <label for="rating">Оценка консультации</label>

      <select id="rating">
        <option>⭐⭐⭐⭐⭐ — Волшебно</option>
        <option>⭐⭐⭐⭐ — Очень понравилось</option>
        <option>⭐⭐⭐ — Хорошо</option>
        <option>⭐⭐ — Нормально</option>
        <option>⭐ — Не понравилось</option>
      </select>

      <label for="review">Ваш отзыв</label>

      <textarea
        id="review"
        placeholder="Поделитесь своими ощущениями, инсайтами или впечатлениями..."
      ></textarea>

      <div class="checkbox-group">

        <label>
          <input type="checkbox" id="anonymous">
          Опубликовать анонимно
        </label>

        <label>
          <input type="checkbox" id="publish">
          Разрешаю опубликовать отзыв на отдельной странице
        </label>

      </div>

      <button type="submit">
        Отправить отзыв 🌙
      </button>

      <div class="note">
        Отправляя форму, вы соглашаетесь на обработку данных.
      </div>

    </form>
  </div>

  <script>
    // ===============================
    // TELEGRAM SETTINGS
    // ===============================

    const TELEGRAM_BOT_TOKEN = "PASTE_YOUR_BOT_TOKEN";
    const TELEGRAM_CHAT_ID = "PASTE_YOUR_CHAT_ID";

    // ===============================
    // FORM SUBMIT
    // ===============================

    const form = document.getElementById("reviewForm");

    form.addEventListener("submit", async (e) => {
      e.preventDefault();

      const name = document.getElementById("name").value || "Не указано";
      const rating = document.getElementById("rating").value;
      const review = document.getElementById("review").value;

      const anonymous = document.getElementById("anonymous").checked
        ? "Да"
        : "Нет";

      const publish = document.getElementById("publish").checked
        ? "Да"
        : "Нет";

      const message = `
🔮 НОВЫЙ ОТЗЫВ

👤 Имя: ${name}

⭐ Оценка:
${rating}

📝 Отзыв:
${review}

🙈 Анонимно: ${anonymous}
🌍 Разрешение на публикацию: ${publish}
      `;

      try {

        await fetch(
          `https://api.telegram.org/bot${TELEGRAM_BOT_TOKEN}/sendMessage`,
          {
            method: "POST",
            headers: {
              "Content-Type": "application/json"
            },
            body: JSON.stringify({
              chat_id: TELEGRAM_CHAT_ID,
              text: message
            })
          }
        );

        alert("Спасибо ✨ Ваш отзыв отправлен.");

        form.reset();

      } catch (error) {

        alert("Ошибка отправки. Попробуйте позже.");

        console.error(error);
      }
    });
  </script>

</body>
</html>
